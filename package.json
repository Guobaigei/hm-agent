{
  "name": "agent-hm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/services/index.ts",
    "chat": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "build": "node scripts/build.mjs",
    "start": "node dist/services/index.cjs",
    "typecheck": "tsc --noEmit"
  },
  "rollAgent": {
    "runtime": {
      "ownership": "on-demand",
      "transport": "stdio"
    },
    "start": {
      "command": "node",
      "args": [
        "dist/mcp/index.cjs"
      ]
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "latest",
    "@roll-agent/sdk": "^0.1.2",
    "ai": "latest",
    "dotenv": "latest",
    "fastify": "latest",
    "pino": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "^0.27.4",
    "tsx": "latest",
    "typescript": "latest"
  }
}
