{
  "name": "hm-agent",
  "version": "0.1.0",
  "private": false,
  "description": "hm-agent：提供海绵项目、公司、门店、品牌信息查询功能",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "SKILL.md",
    "references",
    "README.md"
  ],
  "scripts": {
    "chat": "tsx src/cli/index.ts",
    "build": "node scripts/build.mjs release",
    "build:dev": "node scripts/build.mjs dev",
    "typecheck": "tsc --noEmit"
  },
  "rollAgent": {
    "runtime": {
      "ownership": "on-demand",
      "transport": "stdio"
    },
    "start": {
      "command": "node",
      "args": [
        "dist/mcp/index.cjs"
      ]
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "latest",
    "@roll-agent/sdk": "^0.1.2",
    "ai": "latest",
    "dotenv": "latest",
    "pino": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "^0.27.4",
    "javascript-obfuscator": "^5.4.1",
    "tsx": "latest",
    "typescript": "latest"
  }
}
